{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Development",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/AssetMiddleware.Api/bin/Debug/net10.0/AssetMiddleware.Api.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/AssetMiddleware.Api",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "%s/scalar/v1"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "DOTNET_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:7237;http://localhost:5088"
            }
        },
        {
            "name": "Production",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/AssetMiddleware.Api/bin/Debug/net10.0/AssetMiddleware.Api.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/AssetMiddleware.Api",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "%s/scalar/v1"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Production",
                "DOTNET_ENVIRONMENT": "Production",
                "ASPNETCORE_URLS": "https://localhost:7237;http://localhost:5088"
            }
        }
    ]
}
